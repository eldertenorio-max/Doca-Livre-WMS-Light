# Copie para frontend/.env (não vai para o Git).
# No Render: Environment → mesmas variáveis VITE_* (obrigatório no build).

VITE_SUPABASE_URL=https://qvtnzyqdfhupfsqdqrel.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_publicavel_ou_anon_aqui

# Portal de sistemas (opcional — defaults apontam para produção)
# VITE_WMS_PLUS_URL=https://wms.docalivre.com.br/
# VITE_WMS_PRO_URL=https://doca-livre-wms-pro.onrender.com/
# VITE_WMS_ORIGINAL_URL=https://sistema.docalivre.com.br/login

# SSO (secret fica na Edge Function sso-entrar do Supabase, NÃO no Vite):
# No Dashboard Supabase → Edge Functions → Secrets: SSO_SECRET=<mesmo valor do Render do Pro>
# Deploy: supabase functions deploy sso-entrar --project-ref <ref>
# Acesso direto ao Light em produção redireciona ao portal Plus (VITE_PORTAL_URL / VITE_WMS_PLUS_URL).
# VITE_PORTAL_URL=https://wms.docalivre.com.br/
# Escape local: ?stay=1  ou  VITE_ALLOW_DIRECT_ACCESS=1

# Automação setup (scripts) — NUNCA commitar senhas:
# SUPABASE_PROJECT_REF=qvtnzyqdfhupfsqdqrel
# SUPABASE_PROJECT_REF_OLD=zvazpqdvnlecqadxacgv
# SUPABASE_DB_PASSWORD=senha_postgres_projeto_novo
# SUPABASE_DB_PASSWORD_OLD=senha_postgres_projeto_antigo
# SUPABASE_DB_POOLER_HOST=aws-0-ca-central-1.pooler.supabase.com
# SUPABASE_DB_POOLER_HOST_OLD=aws-1-us-east-1.pooler.supabase.com
# SUPABASE_SERVICE_ROLE_KEY=

# Só para scripts locais (seed, import) — NUNCA no Render nem no Git:
# SUPABASE_URL=https://qvtnzyqdfhupfsqdqrel.supabase.co
